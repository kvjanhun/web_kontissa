{"file":"login-CANAQbyH.js","mappings":";;;;;;;;;;;;;;;;;;;AAMA,YAAQ;AAAA,MACN,MAAM;AAAA,QACJ,EAAE,MAAM,UAAU,SAAS,UAAS;AAAA,MACxC;AAAA,IACA,CAAC;AAEc,cAAS;AACxB,UAAM,YAAY,aAAY;AAC9B,UAAM,EAAE,MAAM,oBAAoB,YAAY,SAAS;AACvD,UAAM,EAAE,OAAO,WAAW;AAC1B,UAAM,EAAE,EAAC,IAAK,aAAY;AAE1B,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,WAAW,IAAI,EAAE;AACvB,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,UAAU,IAAI,KAAK;;AAsBlB,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,4BAAwB,MAAA,CAAA,CAAA,GAAA;UAEtBC,MAAA,eAAA,GAAe;+GACqB,EAAA,OAAA,4BAAA,CAAsC,qBAAKA,MAAA,CAAA,EAAC,gBAAA,CAAA,kCAC9E,EAAA,OAAA,8BAAA,CAAwC,qBAC9CA,MAAA,CAAA,EAAC,kBAAA,CAAA,aAAmCC,eAAAD,MAAA,IAAA,EAAK,QAAQ,eAAiBC,eAAAD,MAAA,IAAA,EAAK,KAAK,wJAM5EA,MAAA,CAAA,EAAC,YAAA,CAAA;;6FAMmD,EAAA,OAAA,4BAAA,CAAsC,qBAAKA,MAAA,CAAA,EAAC,eAAA,CAAA;YAE1FA,MAAA,KAAA,GAAK;6JACXA,MAAA,KAAA,CAAK,CAAA,QAAA;AAAA;;;kHAKgD,EAAA,OAAA,8BAAA,CAAwC,qBAAKA,MAAA,CAAA,EAAC,aAAA,CAAA,oDAGzFA,MAAA,KAAA,CAAK,+CAIbE,cAAA,kBAAgBF,MAAA,KAAA,CAAK,kBACrB,oBAAkBA,MAAA,KAAA,IAAK,gBAAmB,MAAS,kJAE5C,EAAA,iBAAA,6BAAA,QAAA,iCAAA,OAAA,4BAAA,CAA6H,wFAK9E,EAAA,OAAA,8BAAA,CAAwC,qBAAKA,MAAA,CAAA,EAAC,gBAAA,CAAA,uDAG5FA,MAAA,QAAA,CAAQ,2MAKT,EAAA,iBAAA,6BAAA,QAAA,iCAAA,OAAA,4BAAA,CAA6H,uDAM5HA,MAAA,OAAA,CAAO,IAAA,cAAA,kKAGfA,MAAA,OAAA,IAAUA,MAAA,CAAA,EAAC,iBAAA,IAAsBA,MAAA,CAAA,EAAC,cAAA,CAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_ssrRenderAttr"],"sources":["../../../../pages/login.vue"],"sourcesContent":["<script setup>\nimport { useAuthStore } from '~/stores/auth.js'\nimport { useI18nStore } from '~/stores/i18n.js'\n\ndefinePageMeta({ titleKey: 'title.login' })\n\nuseHead({\n  meta: [\n    { name: 'robots', content: 'noindex' }\n  ]\n})\n\nconst router = useRouter()\nconst authStore = useAuthStore()\nconst { user, isAuthenticated } = storeToRefs(authStore)\nconst { login, logout } = authStore\nconst { t } = useI18nStore()\n\nconst email = ref('')\nconst password = ref('')\nconst error = ref('')\nconst loading = ref(false)\n\nasync function handleSubmit() {\n  error.value = ''\n  loading.value = true\n  try {\n    await login(email.value, password.value)\n    router.push('/about')\n  } catch (e) {\n    error.value = e.message\n  } finally {\n    loading.value = false\n  }\n}\n\nasync function handleLogout() {\n  await logout()\n  router.push('/')\n}\n</script>\n\n<template>\n  <div class=\"max-w-sm mx-auto mt-12\">\n    <!-- Already logged in -->\n    <div v-if=\"isAuthenticated\" class=\"text-center space-y-4\">\n      <h1 class=\"text-3xl font-light mb-4\" :style=\"{ color: 'var(--color-text-primary)' }\">{{ t('login.loggedIn') }}</h1>\n      <p :style=\"{ color: 'var(--color-text-secondary)' }\">\n        {{ t('login.signedInAs') }} <strong>{{ user.username }}</strong> ({{ user.email }})\n      </p>\n      <button\n        @click=\"handleLogout\"\n        class=\"bg-accent text-white px-6 py-2 rounded-lg text-sm font-medium transition-opacity duration-200 hover:opacity-90\"\n      >\n        {{ t('nav.logout') }}\n      </button>\n    </div>\n\n    <!-- Login form -->\n    <div v-else>\n      <h1 class=\"text-3xl font-light mb-8 text-center\" :style=\"{ color: 'var(--color-text-primary)' }\">{{ t('login.heading') }}</h1>\n\n      <div v-if=\"error\" id=\"login-error\" role=\"alert\" class=\"mb-4 p-3 rounded-lg text-sm bg-red-500/10 text-red-400 border border-red-500/20\">\n        {{ error }}\n      </div>\n\n      <form @submit.prevent=\"handleSubmit\" class=\"space-y-4\">\n        <div>\n          <label for=\"email\" class=\"block text-sm mb-1\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('login.email') }}</label>\n          <input\n            id=\"email\"\n            v-model=\"email\"\n            type=\"email\"\n            autocomplete=\"email\"\n            required\n            :aria-invalid=\"!!error\"\n            :aria-describedby=\"error ? 'login-error' : undefined\"\n            class=\"w-full px-3 py-2 rounded-lg text-sm outline-none transition-colors duration-200 focus:ring-2 focus:ring-accent\"\n            :style=\"{ backgroundColor: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)', color: 'var(--color-text-primary)' }\"\n          />\n        </div>\n\n        <div>\n          <label for=\"password\" class=\"block text-sm mb-1\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('login.password') }}</label>\n          <input\n            id=\"password\"\n            v-model=\"password\"\n            type=\"password\"\n            autocomplete=\"current-password\"\n            required\n            class=\"w-full px-3 py-2 rounded-lg text-sm outline-none transition-colors duration-200 focus:ring-2 focus:ring-accent\"\n            :style=\"{ backgroundColor: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)', color: 'var(--color-text-primary)' }\"\n          />\n        </div>\n\n        <button\n          type=\"submit\"\n          :disabled=\"loading\"\n          class=\"w-full bg-accent text-white py-2 rounded-lg text-sm font-medium transition-opacity duration-200 hover:opacity-90 disabled:opacity-50\"\n        >\n          {{ loading ? t('login.signingIn') : t('login.signIn') }}\n        </button>\n      </form>\n    </div>\n  </div>\n</template>\n"],"version":3}