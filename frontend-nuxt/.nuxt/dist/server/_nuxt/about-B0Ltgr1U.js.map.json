S,SAAS,MAAM,EAAE,uBAAuB,CAAC,EAAC;AAAA,MAC9E;AAAA,IACA,CAAC;AAED,UAAM,WAAW,IAAI,CAAA,CAAE;AACvB,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,QAAQ,IAAI,IAAI;AAEtB,UAAM,gBAAgB,oBAAI,IAAI,CAAC,aAAa,OAAO,CAAC;AAEpD,UAAM,eAAe,SAAS,MAAM;AAClC,YAAM,SAAS,CAAA;AACf,UAAI,gBAAgB,CAAA;AAEpB,iBAAW,KAAK,SAAS,OAAO;AAC9B,YAAI,cAAc,IAAI,EAAE,YAAY,GAAG;AACrC,wBAAc,KAAK,CAAC;AACpB,cAAI,cAAc,WAAW,GAAG;AAC9B,mBAAO,KAAK,EAAE,MAAM,QAAQ,UAAU,CAAC,GAAG,aAAa,EAAC,CAAE;AAC1D,4BAAgB,CAAA;AAAA,UAClB;AAAA,QACF,OAAO;AACL,cAAI,cAAc,QAAQ;AACxB,mBAAO,KAAK,EAAE,MAAM,UAAU,SAAS,cAAc,CAAC,EAAC,CAAE;AACzD,4BAAgB,CAAA;AAAA,UAClB;AACA,iBAAO,KAAK,EAAE,MAAM,UAAU,SAAS,EAAC,CAAE;AAAA,QAC5C;AAAA,MACF;AACA,UAAI,cAAc,QAAQ;AACxB,eAAO,KAAK,EAAE,MAAM,UAAU,SAAS,cAAc,CAAC,EAAC,CAAE;AAAA,MAC3D;AACA,aAAO;AAAA,IACT,CAAC;;;;UAiBcE,MAAA,OAAA,GAAO;;AACCD,sBAAA,IAAL,MAAC;wGACiC,EAAA,iBAAA,2BAAA,CAA+C,uEAC9C,EAAA,iBAAA,4BAAA,CAAgD,iEACtD,EAAA,iBAAA,4BAAA,CAAgD;;;iBAI3EC,MAAA,KAAA,GAAK;+EAA6C,EAAA,iBAAA,6BAAA,QAAA,gCAAA,CAAyF,kDACzHA,MAAA,CAAA,EAAC,iBAAA,CAAA,iCACtB,EAAA,OAAA,6BAAA,CAAuC,qCAAqBA,MAAA,CAAA,EAAC,qBAAA,CAAA;;;sBAIxCA,MAAA,YAAA,GAAY,CAA1B,OAAO,OAAE;;AACd,cAAA,MAAM,SAAI,QAAA;;0BACO,MAAM,UAAQ,CAAnB,MAAC;;gBAAqB,KAAK,EAAE;AAAA,gBAAK,SAAS;AAAA,gBAAI,SAAS;AAAA;;;;;cAEzD,SAAS,MAAM;AAAA;;;;;;;;;;;;;;;;","names":["_ssrInterpolate","_ssrRenderList","_unref"],"sources":["../../../../components/SectionBlock.vue","../../../../pages/about.vue"],"sourcesContent":["<script setup>\nimport { computed } from 'vue'\n\nconst props = defineProps({\n  section: { type: Object, required: true },\n  compact: { type: Boolean, default: false }\n})\n\nconst pills = computed(() => {\n  if (props.section.section_type !== 'pills') return []\n  return props.section.content.split(',').map(s => s.trim()).filter(Boolean)\n})\n\nconst currentlyItems = computed(() => {\n  if (props.section.section_type !== 'currently') return []\n  return props.section.content.split('\\n').map(line => {\n    const idx = line.indexOf(':')\n    if (idx === -1) return { label: line.trim(), value: '' }\n    return { label: line.slice(0, idx).trim(), value: line.slice(idx + 1).trim() }\n  }).filter(item => item.label)\n})\n</script>\n\n<template>\n  <!-- Quote type: decorative centered blockquote -->\n  <div\n    v-if=\"section.section_type === 'quote'\"\n    :id=\"section.slug\"\n    class=\"mb-6 py-6 text-center\"\n  >\n    <div class=\"quote-mark\" :style=\"{ color: 'var(--color-accent, #ff643e)' }\">&ldquo;</div>\n    <blockquote\n      class=\"text-3xl font-light italic px-6\"\n      :style=\"{ color: 'var(--color-text-primary)' }\"\n    >{{ section.content }}</blockquote>\n    <div class=\"mt-3 mx-auto\" :style=\"{ width: '3rem', height: '2px', background: 'var(--color-accent, #ff643e)', opacity: 0.5 }\"></div>\n  </div>\n\n  <!-- Currently type: card with accent-bordered items -->\n  <article\n    v-else-if=\"section.section_type === 'currently'\"\n    class=\"text-base leading-relaxed rounded-lg overflow-hidden h-full\"\n    :class=\"{ 'mb-6': !compact }\"\n    :id=\"section.slug\"\n    :style=\"{ background: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)' }\"\n  >\n    <div class=\"px-5 pt-4 pb-4\">\n      <h2 class=\"text-xl font-medium m-0 pb-1\">{{ section.title }}</h2>\n      <div :style=\"{ width: '3rem', height: '2px', background: 'var(--color-accent, #ff643e)', opacity: 0.6 }\"></div>\n    </div>\n    <div class=\"px-5 pb-4 space-y-2\">\n      <div\n        v-for=\"(item, i) in currentlyItems\"\n        :key=\"i\"\n        class=\"flex items-baseline gap-3 pl-3 py-1.5 rounded\"\n        :style=\"{ borderLeft: '2px solid var(--color-accent, #ff643e)', background: 'var(--color-bg-tertiary)' }\"\n      >\n        <span class=\"text-xs font-semibold uppercase tracking-wide shrink-0\" :style=\"{ color: 'var(--color-accent, #ff643e)' }\">{{ item.label }}</span>\n        <span v-if=\"item.value\" class=\"text-sm\" :style=\"{ color: 'var(--color-text-primary)' }\">{{ item.value }}</span>\n      </div>\n    </div>\n  </article>\n\n  <!-- Pills type: no accent bar, bright orange pills -->\n  <article\n    v-else-if=\"section.section_type === 'pills'\"\n    class=\"text-base leading-relaxed rounded-lg\"\n    :class=\"{ 'mb-6': !compact, 'h-full': compact }\"\n    :id=\"section.slug\"\n    :style=\"{ background: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)' }\"\n  >\n    <div class=\"px-5 pt-4 pb-4\">\n      <h2 class=\"text-xl font-medium m-0 pb-1\">{{ section.title }}</h2>\n      <div :style=\"{ width: '3rem', height: '2px', background: 'var(--color-accent, #ff643e)', opacity: 0.6 }\"></div>\n    </div>\n    <div class=\"px-5 pb-4 grid grid-cols-3 gap-2\">\n      <div\n        v-for=\"pill in pills\"\n        :key=\"pill\"\n        class=\"pill flex items-center pl-3 py-1.5 rounded text-sm transition-all duration-200\"\n        :style=\"{ borderLeft: '2px solid var(--color-accent, #ff643e)', background: 'var(--color-bg-tertiary)', color: 'var(--color-text-primary)' }\"\n      >{{ pill }}</div>\n    </div>\n  </article>\n\n  <!-- Default: text type -->\n  <article\n    v-else\n    class=\"text-base leading-relaxed rounded-lg\"\n    :class=\"{ 'mb-6': !compact, 'h-full': compact }\"\n    :id=\"section.slug\"\n    :style=\"{ background: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)' }\"\n  >\n    <div class=\"px-5 pt-4 pb-4\">\n      <h2 class=\"text-xl font-medium m-0 pb-1\">{{ section.title }}</h2>\n      <div :style=\"{ width: '3rem', height: '2px', background: 'var(--color-accent, #ff643e)', opacity: 0.6 }\"></div>\n    </div>\n    <div class=\"section-content px-5 pb-4\" v-html=\"section.content\"></div>\n  </article>\n</template>\n\n<style scoped>\n.section-content :deep(p + p) {\n  margin-top: 0.75em;\n}\n.quote-mark {\n  font-size: 4rem;\n  line-height: 1;\n  font-family: Georgia, serif;\n  opacity: 0.6;\n}\n.pill:hover {\n  background: color-mix(in srgb, var(--color-accent, #ff643e) 15%, var(--color-bg-tertiary)) !important;\n}\n</style>\n","<script setup>\nimport { useI18nStore } from '~/stores/i18n.js'\n\ndefinePageMeta({ titleKey: 'title.about' })\n\nconst { t } = useI18nStore()\n\nuseHead({\n  title: computed(() => t('about.metaTitle')),\n  meta: [\n    { name: 'description', content: computed(() => t('about.metaDescription')) }\n  ]\n})\n\nconst sections = ref([])\nconst loading = ref(true)\nconst error = ref(null)\n\nconst COMPACT_TYPES = new Set(['currently', 'pills'])\n\nconst layoutGroups = computed(() => {\n  const groups = []\n  let compactBuffer = []\n\n  for (const s of sections.value) {\n    if (COMPACT_TYPES.has(s.section_type)) {\n      compactBuffer.push(s)\n      if (compactBuffer.length === 2) {\n        groups.push({ type: 'pair', sections: [...compactBuffer] })\n        compactBuffer = []\n      }\n    } else {\n      if (compactBuffer.length) {\n        groups.push({ type: 'single', section: compactBuffer[0] })\n        compactBuffer = []\n      }\n      groups.push({ type: 'single', section: s })\n    }\n  }\n  if (compactBuffer.length) {\n    groups.push({ type: 'single', section: compactBuffer[0] })\n  }\n  return groups\n})\n\nonMounted(async () => {\n  try {\n    const res = await fetch('/api/sections')\n    sections.value = await res.json()\n  } catch (e) {\n    console.error('Failed to load sections:', e)\n    error.value = e\n  } finally {\n    loading.value = false\n  }\n})\n</script>\n\n<template>\n  <div>\n    <div v-if=\"loading\" class=\"space-y-6\">\n      <div v-for=\"n in 3\" :key=\"n\" class=\"animate-pulse\">\n        <div class=\"h-8 rounded w-1/4 mb-3\" :style=\"{ backgroundColor: 'var(--color-bg-tertiary)' }\"></div>\n        <div class=\"h-4 rounded w-full mb-2\" :style=\"{ backgroundColor: 'var(--color-bg-secondary)' }\"></div>\n        <div class=\"h-4 rounded w-3/4\" :style=\"{ backgroundColor: 'var(--color-bg-secondary)' }\"></div>\n      </div>\n    </div>\n\n    <div v-else-if=\"error\" class=\"rounded-lg p-6 text-center\" :style=\"{ backgroundColor: 'var(--color-bg-secondary)', border: '1px solid var(--color-border)' }\">\n      <p class=\"text-red-500 mb-2\">{{ t('about.loadError') }}</p>\n      <p :style=\"{ color: 'var(--color-text-tertiary)' }\" class=\"text-sm\">{{ t('about.loadErrorHint') }}</p>\n    </div>\n\n    <template v-else>\n      <template v-for=\"(group, gi) in layoutGroups\" :key=\"gi\">\n        <div v-if=\"group.type === 'pair'\" class=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-6\">\n          <SectionBlock v-for=\"s in group.sections\" :key=\"s.id\" :section=\"s\" :compact=\"true\" />\n        </div>\n        <SectionBlock v-else :section=\"group.section\" />\n      </template>\n    </template>\n  </div>\n</template>\n"],"version":3}