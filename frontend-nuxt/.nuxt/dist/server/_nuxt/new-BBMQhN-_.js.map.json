{"file":"new-BBMQhN-_.js","mappings":";;;;;;;;;;;;;;;;;;AAQA,UAAM,QAAQ,SAAQ;AACP,cAAS;AACxB,UAAM,EAAE,EAAC,IAAK,aAAY;AAE1B,UAAM,SAAS,SAAS,MAAM,CAAC,CAAC,MAAM,OAAO,IAAI;AAChC,QAAI,IAAI;AACzB,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,WAAW,IAAI,EAAE;AACvB,UAAM,aAAa,IAAI,CAAA,CAAE;AACzB,UAAM,cAAc,IAAI,CAAC,EAAE,QAAQ,IAAI,MAAM,IAAI,MAAM,IAAI,CAAC;AAC5D,UAAM,QAAQ,IAAI,CAAC,EAAE,SAAS,GAAE,CAAE,CAAC;AACnC,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,SAAS,IAAI,KAAK;AACxB,UAAM,UAAU,IAAI,KAAK;;;mBAqFlBA,eAAAC,WAAA,EAAA,OAAM,8BAA6B,GAAA,MAAA,CAAA,gEACO,EAAA,OAAA,4BAAA,CAAsC,qBAC9EC,MAAA,MAAA,IAASA,MAAA,CAAA,EAAC,wBAAA,IAA6BA,MAAA,CAAA,EAAC,uBAAA,CAAA;UAGpCA,MAAA,OAAA,GAAO;oEAAoC,EAAA,OAAA,8BAAA,CAAwC,mCACvFA,MAAA,CAAA,EAAC,iBAAA,CAAA;;;YAIKA,MAAA,KAAA,GAAK;+EAA+CA,MAAA,KAAA,CAAK,CAAA,MAAA;AAAA;;;8EAGtB,EAAA,OAAA,8BAAA,CAAwC,qBAAKA,MAAA,CAAA,EAAC,kBAAA,CAAA,yCAE7EA,MAAA,KAAA,CAAK,0FAINC,eAAA;AAAA;;;QAIP,CAAA,yEAKuC,EAAA,OAAA,8BAAA,CAAwC,qBAAKD,MAAA,CAAA,EAAC,qBAAA,CAAA,oFAI9EC,eAAA;AAAA;;;QAIP,CAAA,0DANQD,MAAA,QAAA,CAAQ,oBAARA,MAAA,QAAA,GAAQ,EAAA,kBAARA,MAAA,QAAA,GAAQ,EAAA,CAAA,IAAA,cAAA,qBAQGA,MAAA,CAAA,EAAC,iBAAA,CAAA;AACCE,sBAAAF,MAAA,UAAA,IAAP,QAAG;0BAA4BG,cAAA,SAAO,GAAG,wCAT/CH,MAAA,QAAA,CAAQ,IAARI,gBAAAJ,MAAA,QAAA,GAS4C,GAAG,IAT/CK,cAAAL,MAAA,QAAA,GAS4C,GAAG,CAAA,IAAA,cAAA,qBAAK,GAAG;;qGAKxB,EAAA,OAAA,8BAAA,CAAwC,qBAAKA,MAAA,CAAA,EAAC,wBAAA,CAAA;sBAChEA,MAAA,WAAA,GAAW,CAAtB,KAAK,MAAC;sDAENG,cAAA,SAAA,IAAI,MAAM,gBAElBA,cAAA,eAAaH,MAAA,CAAA,EAAC,mBAAA,CAAA,mEAEPC,eAAA;AAAA;;;UAIP,CAAA,YAGQE,cAAA,SAAA,IAAI,IAAI,gBAEhBA,cAAA,eAAaH,MAAA,CAAA,EAAC,iBAAA,CAAA,mEAEPC,eAAA;AAAA;;;UAIP,CAAA,YAGQE,cAAA,SAAA,IAAI,IAAI,gBAEhBA,cAAA,eAAaH,MAAA,CAAA,EAAC,2BAAA,CAAA,qEAEPC,eAAA;AAAA;;;UAIP,CAAA,iFAMUK,sBAAAN,MAAA,WAAA,EAAY,WAAM,CAAA,IAAA,cAAA;;qIASvB,EAAA,OAAA,8BAAA,CAAwC,qBAE7CA,MAAA,CAAA,EAAC,0BAAA,CAAA,gFAKoC,EAAA,OAAA,8BAAA,CAAwC,qBAAKA,MAAA,CAAA,EAAC,kBAAA,CAAA;sBAC/DA,MAAA,KAAA,GAAK,CAAjB,MAAM,MAAC;gHACgC,EAAA,OAAA,8BAAA,CAAwC,qBAAK,IAAC,CAAA,qBAG7FG,cAAA,eAAaH,MAAA,CAAA,EAAC,4BAAA,CAAA,uFAGPC,eAAA;AAAA;;;UAIP,CAAA,MARQM,eAAA,KAAK,OAAO,0GAcVD,sBAAAN,MAAA,KAAA,EAAM,WAAM,CAAA,IAAA,cAAA;;qIASjB,EAAA,OAAA,8BAAA,CAAwC,qBAE7CA,MAAA,CAAA,EAAC,oBAAA,CAAA,2FAOOA,MAAA,MAAA,CAAM,IAAA,cAAA,iJAGdO,eAAAP,MAAA,MAAA,IAASA,MAAA,CAAA,EAAC,mBAAA,IAAyBA,gBAASA,MAAA,CAAA,yBAAyBA,MAAA,CAAA,EAAC,mBAAA,CAAA;;UAGxE,IAAIA,MAAA,MAAA,IAAM,YAAeA,aAAM,OAAO,IAAI,KAAA;AAAA,UAC3C,OAAM;AAAA,UACL,OAAO;AAAA;;UAGP;AAAA;2BANH,CASW,GAAAQ,QAAAC,UAAA,aAAA;;uCADNT,MAAA,CAAA,EAAC,mBAAA,CAAA,CAAA,EAAA;AAAA;;gDAADA,MAAA,CAAA,EAAC,mBAAA,CAAA,GAAA,CAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderStyle","_ssrRenderList","_ssrRenderAttr","_ssrLooseContain","_ssrLooseEqual","_ssrIncludeBooleanAttr","_ssrInterpolate","_push","_parent"],"sources":["../../../../pages/recipes/new.vue"],"sourcesContent":["<script setup>\nimport { useI18nStore } from '~/stores/i18n.js'\n\ndefinePageMeta({\n  titleKey: 'title.newRecipe',\n  requiresAuth: true,\n})\n\nconst route = useRoute()\nconst router = useRouter()\nconst { t } = useI18nStore()\n\nconst isEdit = computed(() => !!route.params.slug)\nconst recipeId = ref(null)\nconst title = ref('')\nconst category = ref('')\nconst categories = ref([])\nconst ingredients = ref([{ amount: '', unit: '', name: '' }])\nconst steps = ref([{ content: '' }])\nconst error = ref('')\nconst saving = ref(false)\nconst loading = ref(false)\n\nfunction addIngredient() {\n  ingredients.value.push({ amount: '', unit: '', name: '' })\n}\n\nfunction removeIngredient(index) {\n  if (ingredients.value.length > 1) ingredients.value.splice(index, 1)\n}\n\nfunction addStep() {\n  steps.value.push({ content: '' })\n}\n\nfunction removeStep(index) {\n  if (steps.value.length > 1) steps.value.splice(index, 1)\n}\n\nasync function fetchCategories() {\n  try {\n    const res = await fetch('/api/recipes/categories')\n    if (res.ok) categories.value = await res.json()\n  } catch {}\n}\n\nasync function fetchRecipe() {\n  loading.value = true\n  try {\n    const res = await fetch(`/api/recipes/${route.params.slug}`)\n    if (!res.ok) throw new Error(t('recipeForm.notFound'))\n    const data = await res.json()\n    recipeId.value = data.id\n    title.value = data.title\n    category.value = data.category || ''\n    ingredients.value = data.ingredients.map(i => ({\n      amount: i.amount || '',\n      unit: i.unit || '',\n      name: i.name,\n    }))\n    steps.value = data.steps.map(s => ({ content: s.content }))\n  } catch (e) {\n    error.value = e.message\n  } finally {\n    loading.value = false\n  }\n}\n\nasync function submit() {\n  error.value = ''\n  saving.value = true\n  try {\n    const payload = {\n      title: title.value,\n      category: category.value || null,\n      ingredients: ingredients.value.filter(i => i.name.trim()),\n      steps: steps.value.filter(s => s.content.trim()),\n    }\n\n    const url = isEdit.value ? `/api/recipes/${recipeId.value}` : '/api/recipes'\n    const method = isEdit.value ? 'PUT' : 'POST'\n\n    const res = await fetch(url, {\n      method,\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify(payload),\n    })\n\n    const data = await res.json()\n    if (!res.ok) throw new Error(data.error || t('recipeForm.saveError'))\n\n    router.push(`/recipes/${data.slug}`)\n  } catch (e) {\n    error.value = e.message\n  } finally {\n    saving.value = false\n  }\n}\n\nonMounted(() => {\n  fetchCategories()\n  if (isEdit.value) fetchRecipe()\n})\n</script>\n\n<template>\n  <div class=\"max-w-3xl mx-auto py-8 px-4\">\n    <h1 class=\"text-3xl font-light mb-6\" :style=\"{ color: 'var(--color-text-primary)' }\">\n      {{ isEdit ? t('recipeForm.editHeading') : t('recipeForm.newHeading') }}\n    </h1>\n\n    <p v-if=\"loading\" class=\"text-center py-12\" :style=\"{ color: 'var(--color-text-secondary)' }\" role=\"status\">\n      {{ t('recipes.loading') }}\n    </p>\n\n    <form v-else @submit.prevent=\"submit\" class=\"space-y-6\">\n      <p v-if=\"error\" class=\"text-red-500 text-sm\" role=\"alert\">{{ error }}</p>\n\n      <div>\n        <label class=\"block text-sm mb-1\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('recipeForm.title') }}</label>\n        <input\n          v-model=\"title\"\n          type=\"text\"\n          required\n          class=\"w-full px-4 py-2 rounded-lg text-sm outline-none\"\n          :style=\"{\n            backgroundColor: 'var(--color-input-bg)',\n            border: '1px solid var(--color-border)',\n            color: 'var(--color-text-primary)'\n          }\"\n        />\n      </div>\n\n      <div>\n        <label class=\"block text-sm mb-1\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('recipeForm.category') }}</label>\n        <select\n          v-model=\"category\"\n          class=\"w-full px-4 py-2 rounded-lg text-sm outline-none\"\n          :style=\"{\n            backgroundColor: 'var(--color-input-bg)',\n            border: '1px solid var(--color-border)',\n            color: 'var(--color-text-primary)'\n          }\"\n        >\n          <option value=\"\">{{ t('recipeForm.none') }}</option>\n          <option v-for=\"cat in categories\" :key=\"cat\" :value=\"cat\">{{ cat }}</option>\n        </select>\n      </div>\n\n      <div>\n        <label class=\"block text-sm mb-2\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('recipeForm.ingredients') }}</label>\n        <div v-for=\"(ing, i) in ingredients\" :key=\"i\" class=\"flex gap-2 mb-2\">\n          <input\n            v-model=\"ing.amount\"\n            type=\"text\"\n            :placeholder=\"t('recipeForm.amount')\"\n            class=\"w-20 px-3 py-2 rounded-lg text-sm outline-none\"\n            :style=\"{\n              backgroundColor: 'var(--color-input-bg)',\n              border: '1px solid var(--color-border)',\n              color: 'var(--color-text-primary)'\n            }\"\n          />\n          <input\n            v-model=\"ing.unit\"\n            type=\"text\"\n            :placeholder=\"t('recipeForm.unit')\"\n            class=\"w-20 px-3 py-2 rounded-lg text-sm outline-none\"\n            :style=\"{\n              backgroundColor: 'var(--color-input-bg)',\n              border: '1px solid var(--color-border)',\n              color: 'var(--color-text-primary)'\n            }\"\n          />\n          <input\n            v-model=\"ing.name\"\n            type=\"text\"\n            :placeholder=\"t('recipeForm.ingredientName')\"\n            class=\"flex-1 px-3 py-2 rounded-lg text-sm outline-none\"\n            :style=\"{\n              backgroundColor: 'var(--color-input-bg)',\n              border: '1px solid var(--color-border)',\n              color: 'var(--color-text-primary)'\n            }\"\n          />\n          <button\n            type=\"button\"\n            @click=\"removeIngredient(i)\"\n            class=\"px-2 text-red-500 hover:bg-red-500/10 rounded\"\n            :disabled=\"ingredients.length === 1\"\n          >\n            &times;\n          </button>\n        </div>\n        <button\n          type=\"button\"\n          @click=\"addIngredient\"\n          class=\"text-sm transition-colors duration-200 hover:opacity-80\"\n          :style=\"{ color: 'var(--color-text-secondary)' }\"\n        >\n          {{ t('recipeForm.addIngredient') }}\n        </button>\n      </div>\n\n      <div>\n        <label class=\"block text-sm mb-2\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ t('recipeForm.steps') }}</label>\n        <div v-for=\"(step, i) in steps\" :key=\"i\" class=\"flex gap-2 mb-2\">\n          <span class=\"py-2 text-sm w-6 text-right\" :style=\"{ color: 'var(--color-text-secondary)' }\">{{ i + 1 }}.</span>\n          <textarea\n            v-model=\"step.content\"\n            :placeholder=\"t('recipeForm.stepPlaceholder')\"\n            rows=\"2\"\n            class=\"flex-1 px-3 py-2 rounded-lg text-sm outline-none resize-y\"\n            :style=\"{\n              backgroundColor: 'var(--color-input-bg)',\n              border: '1px solid var(--color-border)',\n              color: 'var(--color-text-primary)'\n            }\"\n          ></textarea>\n          <button\n            type=\"button\"\n            @click=\"removeStep(i)\"\n            class=\"px-2 text-red-500 hover:bg-red-500/10 rounded self-start mt-2\"\n            :disabled=\"steps.length === 1\"\n          >\n            &times;\n          </button>\n        </div>\n        <button\n          type=\"button\"\n          @click=\"addStep\"\n          class=\"text-sm transition-colors duration-200 hover:opacity-80\"\n          :style=\"{ color: 'var(--color-text-secondary)' }\"\n        >\n          {{ t('recipeForm.addStep') }}\n        </button>\n      </div>\n\n      <div class=\"flex gap-3 pt-2\">\n        <button\n          type=\"submit\"\n          :disabled=\"saving\"\n          class=\"px-6 py-2 bg-accent text-white rounded-lg text-sm font-medium transition-opacity duration-200 hover:opacity-90 disabled:opacity-50\"\n        >\n          {{ saving ? t('recipeForm.saving') : (isEdit ? t('recipeForm.update') : t('recipeForm.create')) }}\n        </button>\n        <NuxtLink\n          :to=\"isEdit ? `/recipes/${route.params.slug}` : '/recipes'\"\n          class=\"px-6 py-2 rounded-lg text-sm font-medium transition-colors duration-200\"\n          :style=\"{\n            border: '1px solid var(--color-border)',\n            color: 'var(--color-text-primary)'\n          }\"\n        >\n          {{ t('recipeForm.cancel') }}\n        </NuxtLink>\n      </div>\n    </form>\n  </div>\n</template>\n"],"version":3}